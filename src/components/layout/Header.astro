---
import SearchIcon from "@/components/SearchIcon.astro";
import ThemeToggleIcon from "@/components/ThemeToggleIcon.astro";
import TranslateIcon from "@/components/TranslateIcon.astro";
import { siteConfig } from "../../site.config";

import AuthStatus from "../auth/AuthStatus";
import AuthIcon from "../auth/AuthIcon.astro";
import Auth from "../auth/Auth.astro";
import MenuLinks from "../MenuLinks.astro";
---

<header
	class="group relative mb-28 flex flex-wrap items-center justify-center gap-y-4 sm:flex-nowrap sm:justify-start sm:gap-0"
	id="main-header"
>
	<a href={Astro.url.pathname.includes("eng") ? "/eng" : "/"} class="hidden sm:block ">
		<img
			src="/icon.png"
			alt="Logo"
			class="h-16 w-16 transition-all duration-300 hover:scale-110 hover:brightness-145 sm:me-5 sm:h-21 sm:w-21"
		/>
	</a>
	<div class="flex w-full justify-center sm:w-auto sm:flex-col sm:justify-start">
		<a
			aria-current={Astro.url.pathname === "/" ? "page" : false}
			class="inline-flex items-center grayscale hover:filter-none sm:relative sm:inline-block"
			href={Astro.url.pathname.includes("eng") ? "/eng" : "/"}
		>
			<span class="pt-1 text-4xl font-bold sm:text-3xl">{siteConfig.title}</span>
		</a>
		<nav
			aria-label="Main menu"
			class="bg-global-bg/85 text-accent sm:divide-accent absolute -inset-x-4 top-14 hidden flex-col items-end gap-y-4 rounded-md py-4 shadow backdrop-blur-sm group-[.menu-open]:z-50 group-[.menu-open]:flex sm:static sm:z-auto sm:-ms-4 sm:mt-1 sm:flex sm:flex-row sm:items-center sm:divide-x sm:rounded-none sm:bg-transparent sm:py-0 sm:shadow-none sm:backdrop-blur-none"
			id="navigation-menu"
		>
			<MenuLinks />
		</nav>
	</div>
	<div class="flex w-full items-center justify-center gap-x-1 sm:w-auto sm:ms-auto sm:justify-end">
		<SearchIcon />
		<ThemeToggleIcon />
		{
			Astro.url.pathname === "/" ||
			Astro.url.pathname === "/eng/" ||
			Astro.url.pathname === "/eng" ||
			Astro.url.pathname.includes("/posts") ? (
				<TranslateIcon />
			) : null
		}
		<AuthStatus client:load />
		<AuthIcon />
		<Auth />
		<button
			aria-expanded="false"
			aria-haspopup="menu"
			class="group relative h-7 w-7 sm:hidden"
			id="toggle-navigation-menu"
			type="button"
		>
			<span class="sr-only">Open main menu</span>
			
			
		</button>
	</div>
</header>


<script>
	import { toggleClass } from "@/utils/domElement";
	const signInButton = document.querySelector('#signin-container button[aria-label="Sign In"]');
	const authModal = document.getElementById("auth-modal");
	const closeModalButton = document.getElementById("close-modal");

	if (signInButton && authModal && closeModalButton) {
		signInButton.addEventListener("click", () => {
			authModal.classList.remove("hidden");
		});

		closeModalButton.addEventListener("click", () => {
			authModal.classList.add("hidden");
		});

		window.addEventListener("click", (event) => {
			if (event.target === authModal) {
				authModal.classList.add("hidden");
			}
		});
	}

	window.addEventListener("auth-status", (event: any) => {
		const { session } = event.detail;
		const signInContainer = document.getElementById("signin-container");
		if (signInContainer) {
			if (session) {
				signInContainer.classList.add("hidden");
			} else {
				signInContainer.classList.remove("hidden");
			}
		}
	});

	class MobileNavBtn extends HTMLElement {
		#menuOpen: boolean = false;

		connectedCallback() {
			const headerEl = document.getElementById("main-header")!;
			const mobileButtonEl = this.querySelector<HTMLButtonElement>("button");

			mobileButtonEl?.addEventListener("click", () => {
				if (headerEl) toggleClass(headerEl, "menu-open");
				this.#menuOpen = !this.#menuOpen;
				mobileButtonEl.setAttribute("aria-expanded", this.#menuOpen.toString());
			});
		}
	}

	customElements.define("mobile-button", MobileNavBtn);

	// console.log(Astro.url.pathname);
</script>
